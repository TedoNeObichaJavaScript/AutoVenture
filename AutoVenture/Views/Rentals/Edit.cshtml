@model AutoVenture.Models.Rental
@{
    ViewData["Title"] = "Edit Rental";
}

<section class="max-w-xl mx-auto px-5 py-12">
    <h1 class="font-display text-4xl uppercase border-b-4 border-ink pb-3 mb-6">Edit rental</h1>

    <form asp-action="Edit" class="brutal-card p-6 space-y-4">
        <div asp-validation-summary="ModelOnly" class="text-flare font-bold"></div>
        <input type="hidden" asp-for="RentalId" />

        <div>
            <label asp-for="CarId" class="block font-bold uppercase text-xs mb-1">Car</label>
            <select asp-for="CarId" class="brutal-input" asp-items="ViewBag.CarId"></select>
            <span asp-validation-for="CarId" class="text-flare font-bold text-sm"></span>
        </div>
        <div>
            <label asp-for="CustomerName" class="block font-bold uppercase text-xs mb-1"></label>
            <input asp-for="CustomerName" class="brutal-input" />
            <span asp-validation-for="CustomerName" class="text-flare font-bold text-sm"></span>
        </div>
        <div class="grid grid-cols-2 gap-3">
            <div>
                <label asp-for="StartDate" class="block font-bold uppercase text-xs mb-1"></label>
                <input asp-for="StartDate" type="date" class="brutal-input" />
                <span asp-validation-for="StartDate" class="text-flare font-bold text-sm"></span>
            </div>
            <div>
                <label asp-for="EndDate" class="block font-bold uppercase text-xs mb-1"></label>
                <input asp-for="EndDate" type="date" class="brutal-input" />
                <span asp-validation-for="EndDate" class="text-flare font-bold text-sm"></span>
            </div>
        </div>

        <div class="flex gap-3 pt-2">
            <button type="submit" class="brutal-btn bg-acid px-6 py-3">Save</button>
            <a asp-action="Index" class="brutal-btn bg-paper px-6 py-3">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
