@model AutoVenture.Models.Rental
@{
    ViewData["Title"] = "Rental Details";
}

<section class="max-w-2xl mx-auto px-5 py-12">
    <h1 class="font-display text-4xl uppercase border-b-4 border-ink pb-3 mb-6">Rental #@Model?.RentalId</h1>

    <div class="brutal-card p-6">
        <dl class="grid grid-cols-3 gap-y-3 text-sm">
            <dt class="font-bold uppercase">Car</dt><dd class="col-span-2 font-medium">@Model?.Car?.Make @Model?.Car?.Model</dd>
            <dt class="font-bold uppercase">Customer</dt><dd class="col-span-2 font-medium">@Model?.CustomerName</dd>
            <dt class="font-bold uppercase">Start</dt><dd class="col-span-2 font-medium">@Model?.StartDate.ToString("yyyy-MM-dd")</dd>
            <dt class="font-bold uppercase">End</dt><dd class="col-span-2 font-medium">@(Model?.EndDate?.ToString("yyyy-MM-dd") ?? "—")</dd>
            <dt class="font-bold uppercase">Total</dt><dd class="col-span-2 font-display">$@Model?.TotalPrice</dd>
        </dl>
    </div>

    <div class="flex gap-3 mt-6">
        <a asp-action="Edit" asp-route-id="@Model?.RentalId" class="brutal-btn bg-acid px-6 py-3">Edit</a>
        <a asp-action="Index" class="brutal-btn bg-paper px-6 py-3">Back to list</a>
    </div>
</section>
