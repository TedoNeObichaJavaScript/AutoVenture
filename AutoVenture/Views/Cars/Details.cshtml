@model AutoVenture.Models.Car
@{
    ViewData["Title"] = "Car Details";
}

<section class="max-w-2xl mx-auto px-5 py-12">
    <h1 class="font-display text-4xl uppercase border-b-4 border-ink pb-3 mb-6">@Model?.Make @Model?.Model</h1>

    <div class="brutal-card overflow-hidden">
        @if (!string.IsNullOrEmpty(Model?.ImageUrl))
        {
            <img src="@Url.Content(Model.ImageUrl)" alt="@Model.Make @Model.Model"
                 class="w-full h-64 object-cover border-b-4 border-ink" loading="lazy" />
        }
        <dl class="p-6 grid grid-cols-3 gap-y-3 text-sm">
            <dt class="font-bold uppercase">Make</dt><dd class="col-span-2 font-medium">@Model?.Make</dd>
            <dt class="font-bold uppercase">Model</dt><dd class="col-span-2 font-medium">@Model?.Model</dd>
            <dt class="font-bold uppercase">Year</dt><dd class="col-span-2 font-medium">@Model?.Year</dd>
            <dt class="font-bold uppercase">Price</dt><dd class="col-span-2 font-display">$@Model?.DailyRentPrice/day</dd>
        </dl>
    </div>

    <div class="flex gap-3 mt-6">
        <a asp-action="Edit" asp-route-id="@Model?.CarId" class="brutal-btn bg-acid px-6 py-3">Edit</a>
        <a asp-action="Index" class="brutal-btn bg-paper px-6 py-3">Back to fleet</a>
    </div>
</section>
