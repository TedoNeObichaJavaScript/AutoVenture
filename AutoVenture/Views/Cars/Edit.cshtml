@model AutoVenture.Models.Car
@{
    ViewData["Title"] = "Edit Car";
}

<section class="max-w-xl mx-auto px-5 py-12">
    <h1 class="font-display text-4xl uppercase border-b-4 border-ink pb-3 mb-6">Edit car</h1>

    <form asp-action="Edit" class="brutal-card p-6 space-y-4">
        <div asp-validation-summary="ModelOnly" class="text-flare font-bold"></div>
        <input type="hidden" asp-for="CarId" />

        <div>
            <label asp-for="Make" class="block font-bold uppercase text-xs mb-1"></label>
            <input asp-for="Make" class="brutal-input" />
            <span asp-validation-for="Make" class="text-flare font-bold text-sm"></span>
        </div>
        <div>
            <label asp-for="Model" class="block font-bold uppercase text-xs mb-1"></label>
            <input asp-for="Model" class="brutal-input" />
            <span asp-validation-for="Model" class="text-flare font-bold text-sm"></span>
        </div>
        <div class="grid grid-cols-2 gap-3">
            <div>
                <label asp-for="Year" class="block font-bold uppercase text-xs mb-1"></label>
                <input asp-for="Year" class="brutal-input" />
                <span asp-validation-for="Year" class="text-flare font-bold text-sm"></span>
            </div>
            <div>
                <label asp-for="DailyRentPrice" class="block font-bold uppercase text-xs mb-1"></label>
                <input asp-for="DailyRentPrice" class="brutal-input" />
                <span asp-validation-for="DailyRentPrice" class="text-flare font-bold text-sm"></span>
            </div>
        </div>
        <div>
            <label asp-for="ImageUrl" class="block font-bold uppercase text-xs mb-1">Image URL</label>
            <input asp-for="ImageUrl" class="brutal-input" />
        </div>

        <div class="flex gap-3 pt-2">
            <button type="submit" class="brutal-btn bg-acid px-6 py-3">Save</button>
            <a asp-action="Index" class="brutal-btn bg-paper px-6 py-3">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
