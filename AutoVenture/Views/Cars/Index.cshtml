@model IEnumerable<AutoVenture.Models.Car>
@{
    ViewData["Title"] = "Fleet";
}

<section class="max-w-6xl mx-auto px-5 py-12">
    <div class="border-4 border-ink bg-cobalt text-paper shadow-brutal p-6 md:p-8 mb-10">
        <h1 class="font-display text-4xl md:text-5xl uppercase leading-none">The Fleet</h1>
        <p class="mt-2 font-medium">@(Model?.Count() ?? 0) machines, all yours by the day.</p>
    </div>

    <!-- Controls -->
    <div class="flex flex-col sm:flex-row gap-3 mb-8">
        <input id="fleet-search" type="search" placeholder="Search make / model…"
               class="brutal-input sm:flex-1" />
        <select id="fleet-sort" class="brutal-input sm:w-56">
            <option value="">Sort: featured</option>
            <option value="price-asc">Price: low → high</option>
            <option value="price-desc">Price: high → low</option>
            <option value="name">Name: A → Z</option>
        </select>
    </div>

    <!-- Grid -->
    <div id="fleet-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        @foreach (var car in Model ?? Enumerable.Empty<AutoVenture.Models.Car>())
        {
            <article data-reveal="card"
                     data-name="@car.Make @car.Model"
                     data-price="@car.DailyRentPrice"
                     class="brutal-card p-4 flex flex-col">
                @await Html.PartialAsync("_CarImage", new AutoVenture.Models.CarImageVm
                {
                    Src = car.ImageUrl ?? "/carsphoto/corolla.png",
                    Alt = $"{car.Make} {car.Model}",
                    CssClass = "w-full h-44 object-cover border-3 border-ink mb-4"
                })
                <h3 class="font-display text-xl uppercase">@car.Make @car.Model</h3>
                <p class="text-sm font-medium text-ink/70 mb-3">@car.Year</p>
                <div class="mt-auto flex items-center justify-between">
                    <span class="font-display text-lg">$@car.DailyRentPrice<span class="text-sm font-body">/day</span></span>
                    <button type="button"
                            class="brutal-btn bg-acid px-4 py-2 text-sm"
                            data-book
                            data-car-id="@car.CarId"
                            data-car-name="@car.Make @car.Model"
                            data-car-price="@car.DailyRentPrice"
                            data-car-img="@Url.Content(car.ImageUrl ?? "/carsphoto/corolla.png")"
                            onclick="openBookingModal(this)">
                        Rent
                    </button>
                </div>
            </article>
        }
    </div>
</section>

@await Html.PartialAsync("_BookingModal")
