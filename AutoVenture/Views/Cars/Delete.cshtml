@model AutoVenture.Models.Car
@{
    ViewData["Title"] = "Delete Car";
}

<section class="max-w-xl mx-auto px-5 py-12">
    <div class="border-4 border-ink bg-flare shadow-brutal p-5 mb-6">
        <h1 class="font-display text-3xl uppercase leading-none">Delete this car?</h1>
        <p class="font-bold mt-1">This action cannot be undone.</p>
    </div>

    <div class="brutal-card p-6">
        <dl class="grid grid-cols-3 gap-y-3 text-sm">
            <dt class="font-bold uppercase">Make</dt><dd class="col-span-2 font-medium">@Model?.Make</dd>
            <dt class="font-bold uppercase">Model</dt><dd class="col-span-2 font-medium">@Model?.Model</dd>
            <dt class="font-bold uppercase">Year</dt><dd class="col-span-2 font-medium">@Model?.Year</dd>
            <dt class="font-bold uppercase">Price</dt><dd class="col-span-2 font-display">$@Model?.DailyRentPrice/day</dd>
        </dl>

        <form asp-action="Delete" class="flex gap-3 mt-6">
            <input type="hidden" asp-for="CarId" />
            <button type="submit" class="brutal-btn bg-flare text-paper px-6 py-3">Delete</button>
            <a asp-action="Index" class="brutal-btn bg-paper px-6 py-3">Cancel</a>
        </form>
    </div>
</section>
