@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<section class="max-w-2xl mx-auto py-24 px-5 text-center" data-reveal="hero">
    <div class="brutal-card bg-flare p-10 rotate-1">
        <p class="font-display text-7xl leading-none">500</p>
        <h1 class="font-display text-3xl uppercase mt-2">Something broke</h1>
        <p class="mt-3 font-bold">An error occurred while processing your request.</p>

        @if (Model?.ShowRequestId ?? false)
        {
            <p class="mt-4 text-sm font-mono break-all">
                Request ID: <code class="bg-ink text-paper px-1">@Model.RequestId</code>
            </p>
        }

        <a href="@Url.Action("Index", "Home")" class="brutal-btn inline-block mt-8 bg-ink text-paper px-8 py-3">← Back home</a>
    </div>
</section>
