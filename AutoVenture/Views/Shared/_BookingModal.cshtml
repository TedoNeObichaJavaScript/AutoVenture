@*
    Shared booking modal — used by both the home page and the fleet catalog.
    Purely presentational; site.js (openBookingModal / submit handler) drives it
    and POSTs a BookingRequest to /Rentals/Book.
*@
<div id="booking-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-ink/70 backdrop-blur-sm">
    <div class="brutal-card w-full max-w-lg max-h-[92vh] overflow-y-auto p-0" data-modal-panel>
        <div class="flex items-stretch justify-between border-b-4 border-ink">
            <div class="p-4">
                <p class="text-xs font-bold uppercase tracking-widest text-flare">Reserve</p>
                <h2 id="bm-title" class="font-display text-2xl leading-none mt-1">Car</h2>
                <p class="mt-1 text-sm font-bold"><span id="bm-price">0</span> / day</p>
            </div>
            <button type="button" onclick="closeBookingModal()"
                    class="bg-flare border-l-4 border-ink px-5 font-display text-2xl hover:bg-ink hover:text-paper transition-colors"
                    aria-label="Close">&times;</button>
        </div>

        <img id="bm-img" src="" alt="" class="w-full h-44 object-cover border-b-4 border-ink bg-paper" />

        <form id="booking-form" class="p-4 space-y-3">
            <input type="hidden" name="CarId" id="bm-carid" />

            <div class="grid grid-cols-3 gap-2">
                <input class="brutal-input" name="FirstName" placeholder="First" required maxlength="60" />
                <input class="brutal-input" name="MiddleName" placeholder="Middle" maxlength="60" />
                <input class="brutal-input" name="LastName" placeholder="Last" required maxlength="60" />
            </div>

            <div class="grid grid-cols-2 gap-2">
                <label class="block text-xs font-bold uppercase">Pick-up
                    <input class="brutal-input mt-1" type="date" name="StartDate" id="bm-start" required />
                </label>
                <label class="block text-xs font-bold uppercase">Return
                    <input class="brutal-input mt-1" type="date" name="EndDate" id="bm-end" required />
                </label>
            </div>

            <input class="brutal-input" name="PickupSite" placeholder="Pick-up location" required maxlength="120" />
            <input class="brutal-input" name="Egn" placeholder="EGN (personal ID)" required inputmode="numeric" pattern="\d{10}" />

            <div class="grid grid-cols-[2fr_1fr_1fr] gap-2">
                <input class="brutal-input" name="CreditCard" placeholder="Card number" required inputmode="numeric" />
                <input class="brutal-input" name="ExpirationDate" placeholder="MM/YY" required />
                <input class="brutal-input" name="Ccv" placeholder="CCV" required inputmode="numeric" pattern="\d{3,4}" />
            </div>

            <ul id="bm-errors" class="hidden text-sm font-bold text-flare list-disc list-inside border-3 border-flare bg-flare/10 p-2"></ul>

            <button type="submit" id="bm-submit"
                    class="brutal-btn w-full bg-acid py-3 text-ink">
                Confirm booking
            </button>

            <div id="bm-success" class="hidden border-4 border-ink bg-acid p-3 text-center">
                <p class="font-display text-lg">Locked in. 🏁</p>
                <p class="text-sm font-bold mt-1">Total: $<span id="bm-total">0</span></p>
            </div>
        </form>
    </div>
</div>
