@model IEnumerable<AutoVenture.Models.Car>
@{
    ViewData["Title"] = "Home";
    var featured = Model?.Take(3) ?? Enumerable.Empty<AutoVenture.Models.Car>();
}

<!-- Hero -->
<section class="relative border-b-4 border-ink overflow-hidden">
    <!-- graffiti splat decorations (animated in via GSAP) -->
    <svg data-splat-deco aria-hidden="true" class="pointer-events-none absolute -top-10 -left-10 w-56 h-56 text-acid opacity-0 z-0" viewBox="0 0 200 200" fill="currentColor">
        <path d="M48 12c20-6 36 10 52 4s34 6 40 26-10 34-4 52-14 36-34 40-36-10-54-6-36-8-42-28 8-34 2-52 8-38 28-44 12 8 12 8z" stroke="#0a0a0a" stroke-width="4"/>
    </svg>
    <svg data-splat-deco aria-hidden="true" class="pointer-events-none absolute top-1/2 -right-12 w-48 h-48 text-cobalt opacity-0 z-0" viewBox="0 0 200 200" fill="currentColor">
        <path d="M100 8l22 40 46-8-20 42 38 26-44 14 6 46-40-22-30 34-12-46-46 4 26-38-34-30 46-12-4-46 40 22z" stroke="#0a0a0a" stroke-width="4"/>
    </svg>
    <svg data-splat-deco aria-hidden="true" class="pointer-events-none absolute bottom-2 left-1/3 w-32 h-32 text-flare opacity-0 z-0" viewBox="0 0 200 200" fill="currentColor">
        <circle cx="100" cy="100" r="60" stroke="#0a0a0a" stroke-width="4"/>
        <circle cx="170" cy="60" r="14" stroke="#0a0a0a" stroke-width="4"/>
        <circle cx="40" cy="160" r="18" stroke="#0a0a0a" stroke-width="4"/>
    </svg>

    <div class="relative z-10 max-w-6xl mx-auto px-5 py-16 md:py-24 grid md:grid-cols-2 gap-8 items-center">
        <div>
            <p data-reveal="hero" class="inline-block bg-cobalt text-paper font-bold uppercase text-xs tracking-widest px-3 py-1 border-3 border-ink shadow-brutalSm mb-5">
                No fuss · No stress
            </p>
            <h1 data-reveal="hero" class="font-display text-5xl md:text-7xl uppercase leading-[0.95]">
                Rent.<br />Drive.<br /><span class="bg-acid px-2 -rotate-1 inline-block border-3 border-ink">Repeat.</span>
            </h1>
            <p data-reveal="hero" class="mt-6 text-lg max-w-md font-medium">
                Pick your machine, lock the dates, hit the road. Honest pricing, zero paperwork theatre.
            </p>
            <a data-reveal="hero" href="@Url.Action("Index", "Cars")"
               class="brutal-btn inline-block mt-8 bg-ink text-paper px-8 py-4 text-lg">
                Explore the fleet →
            </a>
        </div>
        <div data-reveal="hero" class="relative">
            <div class="brutal-card p-0 -rotate-2">
                <img src="@Url.Content("~/carsphoto/mx5.png")" alt="Featured car"
                     class="w-full h-72 object-cover" loading="eager" />
            </div>
            <div class="absolute -bottom-4 -left-4 bg-flare text-ink font-display text-xl px-4 py-2 border-4 border-ink shadow-brutal rotate-3">
                From $28/day
            </div>
        </div>
    </div>
</section>

<!-- Featured -->
<section class="max-w-6xl mx-auto px-5 py-14">
    <div class="flex items-end justify-between mb-8">
        <h2 class="font-display text-3xl md:text-4xl uppercase">Popular rides</h2>
        <a asp-controller="Cars" asp-action="Index" class="nav-brutal hidden sm:inline-block text-sm font-bold uppercase">See all</a>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
        @foreach (var car in featured)
        {
            <article data-reveal="card" class="brutal-card p-4 flex flex-col">
                @await Html.PartialAsync("_CarImage", new AutoVenture.Models.CarImageVm
                {
                    Src = car.ImageUrl ?? "/carsphoto/corolla.png",
                    Alt = $"{car.Make} {car.Model}",
                    CssClass = "w-full h-44 object-cover border-3 border-ink mb-4"
                })
                <h3 class="font-display text-xl uppercase">@car.Make @car.Model</h3>
                <p class="text-sm font-medium text-ink/70 mb-3">@car.Year · Ready to roll.</p>
                <div class="mt-auto flex items-center justify-between">
                    <span class="font-display text-lg">$@car.DailyRentPrice<span class="text-sm font-body">/day</span></span>
                    <button type="button"
                            class="brutal-btn bg-acid px-4 py-2 text-sm"
                            data-book
                            data-car-id="@car.CarId"
                            data-car-name="@car.Make @car.Model"
                            data-car-price="@car.DailyRentPrice"
                            data-car-img="@Url.Content(car.ImageUrl ?? "/carsphoto/corolla.png")"
                            onclick="openBookingModal(this)">
                        Rent
                    </button>
                </div>
            </article>
        }
    </div>
</section>

@await Html.PartialAsync("_BookingModal")
