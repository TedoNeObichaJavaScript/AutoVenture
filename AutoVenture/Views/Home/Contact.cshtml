@model AutoVenture.Models.ContactViewModel
@{
    ViewData["Title"] = "Свържи се с нас";
}

<section class="max-w-5xl mx-auto py-12 px-5">
    <div class="border-4 border-ink bg-flare text-ink shadow-brutal p-6 md:p-8 mb-10 -rotate-1">
        <h1 class="font-display text-4xl md:text-5xl uppercase leading-none">Свържи се</h1>
    </div>

    @if (ViewBag.Message != null)
    {
        <p class="border-3 border-ink bg-acid p-3 font-bold mb-6">@ViewBag.Message</p>
    }

    <div class="grid gap-8 md:grid-cols-2">
        <div class="space-y-3">
            <div class="brutal-card p-4"><strong class="font-display uppercase text-sm">📍 Адрес</strong><p class="font-medium">Tursete Tedo ot Karnobat</p></div>
            <div class="brutal-card p-4"><strong class="font-display uppercase text-sm">📞 Телефон</strong><p class="font-bold">Nomer nqma :D</p></div>
            <div class="brutal-card p-4"><strong class="font-display uppercase text-sm">✉️ Имейл</strong><p><a href="mailto:nqkuvemail@gmail.com" class="font-bold underline decoration-2 underline-offset-2 hover:text-cobalt">nqkuvemail@gmail.com</a></p></div>
        </div>

        @using (Html.BeginForm("Contact", "Home", FormMethod.Post, new { @class = "brutal-card p-5 space-y-4" }))
        {
            @Html.AntiForgeryToken()
            <div>
                <label class="block font-bold uppercase text-xs mb-1">Вашето име</label>
                @Html.TextBoxFor(m => m.Name, new { @class = "brutal-input", required = "required" })
                @Html.ValidationMessageFor(m => m.Name, null, new { @class = "text-flare font-bold text-sm" })
            </div>
            <div>
                <label class="block font-bold uppercase text-xs mb-1">Имейл адрес</label>
                @Html.TextBoxFor(m => m.Email, new { @class = "brutal-input", required = "required", type = "email" })
                @Html.ValidationMessageFor(m => m.Email, null, new { @class = "text-flare font-bold text-sm" })
            </div>
            <div>
                <label class="block font-bold uppercase text-xs mb-1">Съобщение</label>
                @Html.TextAreaFor(m => m.Message, new { @class = "brutal-input", required = "required", rows = "5" })
                @Html.ValidationMessageFor(m => m.Message, null, new { @class = "text-flare font-bold text-sm" })
            </div>
            <button type="submit" class="brutal-btn w-full bg-acid py-3">Изпрати →</button>
        }
    </div>

    <div class="brutal-card p-0 mt-10 overflow-hidden">
        <iframe class="w-full h-72 grayscale contrast-125" title="Map" loading="lazy"
                src="https://maps.google.com/maps?q=Карнобат&t=&z=13&ie=UTF8&iwloc=&output=embed"
                frameborder="0" allowfullscreen></iframe>
    </div>
</section>
